# ----- Database (PostgreSQL 14+) -----
# The storefront ships with an in-memory mock catalog so it runs with NO DB.
# Set this to switch lib/db.ts to a real pg pool (see lib/db.ts TODO).
DATABASE_URL=postgres://palash:password@localhost:5432/palash_telecom

# ----- Auth (admin panel) -----
# 32+ char random string. Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-string-min-32-chars
# Seed admin login (demo). Change before deploying.
ADMIN_EMAIL=admin@palashtelecom.com
# bcrypt hash of the admin password. Generate: npm run hash -- 'YourPassword'
# Default below is the hash of "palash-admin" — CHANGE THIS.
ADMIN_PASSWORD_HASH=

# ----- Dev convenience -----
# When "1" AND NODE_ENV!=production, /admin/* is reachable without login.
# MUST be unset / "0" in production.
ADMIN_DEV_BYPASS=1

# ----- Payment gateway (SSLCommerz) -----
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWD=
SSLCZ_IS_LIVE=false
